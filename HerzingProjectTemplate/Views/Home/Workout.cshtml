@model Workout

@{
    ViewData["Title"] = "Workout";
}

<div class="workout-structure"> @* /*Body*/ *@

    <div class="sidebar"> @* /*SideBar*/ *@
        <div class="sidebar-content">

            @if (Model?.SelectedExercises?.Count >0)
            {
                @foreach (var exercise in Model.SelectedExercises)
                {
                    <div><span>@exercise</span></div>
                }
            }
           
            
            <form action="/" method="post" id="sidebar-form"> 
                <div class="">
                    <label class="sidebar-div-text" for="Resistancetraining">Resistance Training</label> @* /*Resistance training*/ *@
                    <input type="radio" id="Resistancetraining" value="Resistance Training" name="SelectedExercises" /><br />
                    <img class="exercise-icon" src="~/images/Dumbell.png" alt="resistance" />
                </div>
            <br />
            <hr />
            <br />
                <div class="">
                    <label for="Endurancetraining">Endurance Training</label> @* /*Endurance training*/ *@
                    <input type="radio" id="Endurancetraining" value="Endurance Training" name="SelectedExercises" /><br />
                    <img class="exercise-icon" src="~/images/endurance.png" alt="endurance" />
                </div>
            <br />
            <hr />
            <br />
                <div class="">
                    <label for="BodyWeightTraining">Body Weight Training</label> @* /*Body Weight training*/ *@
                    <input type="radio" id="BodyWeightTraining" value="Body Weight Training" name="SelectedExercises" /><br />
                    <img class="exercise-icon" src="~/images/pushup.png" alt="body-weight" />
                </div>
            </form>
        </div>
    </div> 

    
    <div class="workout-body-content">
      
        <div class="container"> @* /*Body-header*/ *@
            <div class="search-container">
                <input class="input" type="text">
                <svg viewBox="0 0 24 24" class="search__icon">
                    <g>
                        <path d="M21.53 20.47l-3.66-3.66C19.195 15.24 20 13.214 20 11c0-4.97-4.03-9-9-9s-9 4.03-9 9 4.03 9 9 9c2.215 0 4.24-.804 5.808-2.13l3.66 3.66c.147.146.34.22.53.22s.385-.073.53-.22c.295-.293.295-.767.002-1.06zM3.5 11c0-4.135 3.365-7.5 7.5-7.5s7.5 3.365 7.5 7.5-3.365 7.5-7.5 7.5-7.5-3.365-7.5-7.5z">
                        </path>
                    </g>
                </svg>
            </div>
        </div>

        <div id="my_content"></div>
       
        <div class="workout-cards1" id="workout-cards1" style="display:none;">@* /*Resistance training*/ *@
            <div class="card" style="width: 18rem;">
                <img src="~/images/endurance-card.jpg" class="workout-card-images" alt="endurance">
                <div class="card-body">
                    <h5 class="card-title">RESISTANCE TRAINING</h5>
                    <p class="card-text">BEGINNER WORKOUTS</p>
                    <p>Beginners focus on learning movement patterns, building stability, and developing confidence.</p>
                    <a href="#" class="btn btn-primary">Open</a>

                    <hr />

                    <form action="/" method="post">
                        <div class="inner-wrapper1">
                            <label class="collapse-label" for="BarbellSquat(B)"><b>Barbell Squat</b></label>
                            <input type="checkbox" id="BarbellSquat(B)" value="Barbell Squat" name="SelectedExercises" class="collapse-content" /><br />
                            <div class="collapse-div">
                                <b>Description:</b> Learn proper depth, bracing, and bar path while using manageable loads.<br />
                                <b>Reps:</b> 3 x 8 - 10 <br />
                                <b>Rest:</b> 90 seconds
                            </div>
                        </div>

                        <hr />

                        <div class="inner-wrapper1">
                            <label class="collapse-label" for="DumbbellBenchPress(B)"><b>Dumbbell Bench Press</b></label>
                            <input type="checkbox" id="DumbbellBenchPress(B)" value="Dumbbell Bench Press" name="SelectedExercises" class="collapse-content" /><br />
                            <div class="collapse-div">
                                <b>Description:</b> Build foundational pressing strength and shoulder stability.<br />
                                <b>Reps:</b> 3 x 10 - 12 <br />
                                <b>Rest:</b> 60 - 90 seconds
                            </div>
                        </div>

                        <hr />

                        <div class="inner-wrapper1">
                            <label class="collapse-label" for="BentOverBarbellRow(B)"><b>Bent Over Barbell Row</b></label>
                            <input type="checkbox" id="BentOverBarbellRow(B)" value="Bent Over Barbell Row" name="SelectedExercises" class="collapse-content" /><br />
                            <div class="collapse-div">
                                <b>Description:</b> Introduce hip hinge stability while strengthening the upper back.<br />
                                <b>Reps:</b> 3 x 8 - 10<br />
                                <b>Rest:</b> 90 seconds
                            </div>
                        </div>

                        <hr />

                        <div class="inner-wrapper1">
                            <label class="collapse-label" for="RomanianDeadlift(B)"><b>Romanian Deadlift</b></label>
                            <input type="checkbox" id="RomanianDeadlift(B)" value="Romanian Deadlift" name="SelectedExercises" class="collapse-content" /><br />
                            <div class="collapse-div">
                                <b>Description:</b> Learn the hip hinge pattern with controlled tempo and light loads.<br />
                                <b>Reps:</b> 3 x 8 - 10<br />
                                <b>Rest:</b> 90 seconds
                            </div>
                        </div>

                        <hr />

                        <div class="inner-wrapper1">
                            <label class="collapse-label" for="SeatedDumbbellShoulderPress(B)"><b>Seated Dumbbell Shoulder Press</b></label>
                            <input type="checkbox" id="SeatedDumbbellShoulderPress(B)" value="Seated Dumbbell Shoulder Press" name="SelectedExercises" class="collapse-content" /><br />
                            <div class="collapse-div">
                                <b>Description:</b> Build overhead pressing strength with support from the seatback.<br />
                                <b>Reps:</b> 3 x 10 - 12<br />
                                <b>Rest:</b> 60 - 90 seconds
                            </div>
                        </div>
                    </form>
                </div>
            </div>


            <div class="card" style="width: 18rem;">
                <img src="~/images/body-weight-card.jpg" class="workout-card-images" alt="endurance">
                <div class="card-body">
