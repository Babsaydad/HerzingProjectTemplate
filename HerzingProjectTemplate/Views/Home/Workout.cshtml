@section Scripts {
    <script>
              // 1. Grab references to the elements
          const allRadiosForm = document.getElementById("sidebar-form");
          const outputContainer = document.getElementById("my_content");

          // These are your "source" templates
          const resistance = document.getElementById("workout-cards1");
          const endurance = document.getElementById("workout-cards2");
          const bodyWeight = document.getElementById("workout-cards3");

          allRadiosForm.addEventListener('change', (event) => {
              // Ensure we are only reacting to radio button inputs
          if (event.target.type !== "radio") return;

          const selectedValue = event.target.value;

          // 2. Determine which content to show based on the value
          if (selectedValue === "Resistance Training") {
              outputContainer.innerHTML = resistance.innerHTML;
          } else if (selectedValue === "Endurance Training") {
              outputContainer.innerHTML = endurance.innerHTML;
          } else if (selectedValue === "Body Weight Training") {
              outputContainer.innerHTML = bodyWeight.innerHTML;
          } else {
              // Optional: Clear if a value doesn't match
              outputContainer.innerHTML = "";
          }
        });
    </script>
}




            
            